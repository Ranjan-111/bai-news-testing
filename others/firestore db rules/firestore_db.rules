rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 1. ARTICLES (Fixed Syntax)
    // =========================================================
    match /articles/{articleId} {
      allow read: if true; 
      
      // Allow logged-in users to submit new articles
      allow create: if request.auth != null;

      // Allow Admin OR the Original Author to edit/delete everything
      // OR Allow anyone to update the 'stats' (for likes/views)
      allow update: if (request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data.role == 'admin' ||
        resource.data.authorId == request.auth.uid
      )) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']));

      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data.role == 'admin' ||
        resource.data.authorId == request.auth.uid
      );
    }

    // =========================================================
    // 2. USERS COLLECTION (Fixed Syntax)
    // =========================================================
    match /users/{email} {
      allow read: if true; 

      // Allow owner or Admin to write; Also allow guests to subscribe to newsletter
      allow write: if (request.auth != null && (
        request.auth.token.email.lowerCase() == email.lowerCase() || 
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data.role == 'admin'
      )) || (request.resource.data.isNewsletterSubscribed == true);
    }

    // =========================================================
    // 3. SAVED ARTICLES
    // =========================================================
    match /savedArticles/{saveId} {
      // Users can only read or delete their own saved bookmarks
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Users can only create a save if they are the owner
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // =========================================================
    // 4. NEWSLETTER & AUTHORS (Fixed Syntax)
    // =========================================================
    match /newsletter/{docId} {
      allow create: if true;
      allow read: if false; 
    }
    
    match /authors/{email} {
      allow read: if true; 
      allow write: if request.auth != null && (
        request.auth.token.email.lowerCase() == email.lowerCase() ||
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data.role == 'admin'
      );
    }
    
    match /author_requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data.role == 'admin';
    }
  }
}